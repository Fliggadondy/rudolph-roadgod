# RUDOLPH ROADGOD Environment Configuration
# Copy this file to .env and fill in your values

# Blockchain
RUDOLPH_RPC=http://localhost:8545
RUDOLPH_TCOIN=0x5FbDB...
RUDOLPH_DISPATCH=0xe7f17...

# Fleet Server
RUDOLPH_FLEET_PORT=8080
RUDOLPH_P2P_PORT=8081

# AI / LLM
RUDOLPH_OLLAMA=http://127.0.0.1:11434/api/generate
RUDOLPH_MODEL=qwen2.5:3b

# IoT
RUDOLPH_MQTT=mqtt://localhost:1883

# GhostGrid Proxies (comma-separated)
RUDOLPH_PROXIES=http://localhost:8888
